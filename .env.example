# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA comite .env no Git — ele contém credenciais.

# Token do bot (Discord Developer Portal → Bot → Reset Token)
DISCORD_TOKEN=cole_o_token_aqui

# ID do servidor onde o bot deve operar (guild único — seção 9.3 da spec)
GUILD_ID=000000000000000000

# ID do usuário orientador que recebe resumos semanais por DM
ORIENTADOR_ID=000000000000000000

# Caminho do arquivo SQLite (será criado automaticamente)
DATABASE_PATH=./data/cutucao.db

# Timezone para cron jobs (America/Recife = horário de Brasília sem DST)
TZ=America/Recife
